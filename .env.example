# OpenXenos — environment variables
# Copy this file to .env and fill in your values.

# DeepSeek Anthropic API credentials (required)
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=your-api-key-here
ANTHROPIC_MODEL=deepseek-v4-pro

# OpenXenos server settings (optional)
OPENXENOS_PORT=2222
OPENXENOS_HOST=0.0.0.0
OPENXENOS_RELOAD=false
OPENXENOS_PANEL_SIZE=3
OPENXENOS_PHASE1_TEMP=0.8
OPENXENOS_PHASE2_TEMP=0.5
OPENXENOS_MAX_ROUNDS=10
OPENXENOS_MAX_TOKENS=32000
OPENXENOS_THINKING_BUDGET=16000
OPENXENOS_TIMEOUT=300
